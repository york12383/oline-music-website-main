<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.music.mapper.SongListMapper">
  <resultMap id="BaseResultMap" type="com.example.music.model.domain.SongList">
    <id column="id" property="id" jdbcType="INTEGER" />
    <result column="title" property="title" jdbcType="VARCHAR" />
    <result column="pic" property="pic" jdbcType="VARCHAR" />
    <result column="style" property="style" jdbcType="VARCHAR" />
    <result column="type" property="type" jdbcType="TINYINT" />
    <result column="consumer" property="Consumer" jdbcType="INTEGER" />
  </resultMap>
  <resultMap id="ResultMapWithBLOBs" type="com.example.music.model.domain.SongList" extends="BaseResultMap">
    <result column="introduction" property="introduction" jdbcType="LONGVARCHAR" />
  </resultMap>
  <!-- 修改这里：添加 type 字段 -->
  <sql id="Base_Column_List">
    id, title, pic, style, type, consumer
  </sql>

  <sql id="Blob_Column_List">
    introduction
  </sql>

  <select id="selectSongListNameById" parameterType="java.lang.Long" resultType="java.lang.String">
    SELECT title FROM song_list WHERE id = #{songListId}
  </select>

  <select id="getSongListByConsumerId" parameterType="int" resultMap="ResultMapWithBLOBs">
    SELECT
    <include refid="Base_Column_List"/>,
    <include refid="Blob_Column_List"/>,
    consumer
    FROM song_list
    WHERE consumer = #{ConsumerId}
  </select>



  <select id="getSongListByConsumer" parameterType="int" resultMap="ResultMapWithBLOBs">
    SELECT
    id
    FROM song_list
    WHERE consumer = #{ConsumerId}
  </select>


</mapper>
