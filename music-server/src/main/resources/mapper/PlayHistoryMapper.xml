<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.music.mapper.PlayHistoryMapper">

    <resultMap id="BaseResultMap" type="com.example.music.model.domain.PlayHistory">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="song_id" property="songId"/>
        <result column="play_time" property="playTime"/>
        <result column="duration" property="duration"/>
    </resultMap>
    
    <sql id="Base_Column_List">
        id, user_id, song_id, play_time, duration
    </sql>

    <insert id="insert" parameterType="com.example.music.model.domain.PlayHistory">
        INSERT INTO play_history (user_id, song_id, play_time, duration)
        VALUES (#{userId}, #{songId}, #{playTime}, #{duration})
    </insert>
    
    <select id="selectByUserId" parameterType="int" resultMap="BaseResultMap">
        SELECT 
        <include refid="Base_Column_List"/>
        FROM play_history WHERE user_id = #{userId} ORDER BY play_time DESC
    </select>

</mapper>