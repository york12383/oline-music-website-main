<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.music.mapper.ConsumerMapper">
  <resultMap id="BaseResultMap" type="com.example.music.model.domain.Consumer">
    <result column="id" property="id" jdbcType="INTEGER" />
    <!--新添加的字段-->
    <result column="singer_id" property="singerId" jdbcType="INTEGER" />
    <!--新添加的字段-->
    <result column="username" property="username" jdbcType="VARCHAR" />
    <result column="password" property="password" jdbcType="VARCHAR" />
    <result column="sex" property="sex" jdbcType="TINYINT" />
    <result column="phone_num" property="phoneNum" jdbcType="CHAR" />
    <result column="email" property="email" jdbcType="CHAR" />
    <result column="birth" property="birth" jdbcType="TIMESTAMP" />
    <result column="introduction" property="introduction" jdbcType="VARCHAR" />
    <result column="location" property="location" jdbcType="VARCHAR" />
    <result column="avator" property="avator" jdbcType="VARCHAR" />
    <result column="create_time" property="createTime" jdbcType="TIMESTAMP" />
    <result column="update_time" property="updateTime" jdbcType="TIMESTAMP" />
    <result column="deleted" property="deleted" jdbcType="TINYINT" />
  </resultMap>
  <sql id="Base_Column_List">
    id, username, password, sex, phone_num, email, birth, introduction, location, avator, create_time, update_time, singer_id, deleted
  </sql>
<!--  作用：MyBatis 映射文件，定义 SQL 查询语句和结果映射。-->
<!--  关键内容：-->
<!--  <resultMap>：定义数据库字段与 Java 对象的映射关系。-->
<!--  <sql>：定义 SQL 片段，用于复用。-->

  <select id="selectConsumerNameById" parameterType="java.lang.Integer" resultType="java.lang.String">
    SELECT CASE WHEN deleted = 1 THEN '已注销用户' ELSE username END FROM consumer WHERE id = #{id}
  </select>

  <select id="selectIdByconsumerName" parameterType="java.lang.String" resultType="java.lang.Integer">
    SELECT id FROM consumer WHERE username = #{username} AND deleted = 0
  </select>



</mapper>
